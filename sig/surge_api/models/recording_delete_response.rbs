          id: String,
          contact: SurgeAPI::Contact,
          duration: Integer,
          initiated_at: Time,
          status: SurgeAPI::Models::RecordingDeleteResponse::Call::status
        }

        type status =
          :busy
          | :canceled
          | :completed
          | :failed
          | :in_progress
          | :missed
          | :no_answer
          | :queued
          | :ringing

        module Status
          extend SurgeAPI::Internal::Type::Enum

          BUSY: :busy
          CANCELED: :canceled
          COMPLETED: :completed
          FAILED: :failed
          IN_PROGRESS: :in_progress
          MISSED: :missed
          NO_ANSWER: :no_answer
          QUEUED: :queued
          RINGING: :ringing

          def self?.values: -> ::Array[SurgeAPI::Models::RecordingDeleteResponse::Call::status]
